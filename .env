# =========================

# Duck Dating Apps / PSD

# Environment Variables

# =========================

# -------------------------

# SERVER

# -------------------------

PORT=3000
NODE_ENV=development
ADMIN_PASSWORD=changeme

# -------------------------

# FRONTEND URL

# -------------------------

FRONTEND_URL=http://localhost:5173

# -------------------------

# EVENTBRITE API

# -------------------------

EVENTBRITE_TOKEN=SKJ5T5KFGIIOBSOSIXWA

# -------------------------

# MEETUP API

# Get key at: https://secure.meetup.com/oauth/authorize?client_id=YOUR_ID&response_type=code&redirect_uri=http://localhost:3000

# (Fallback for events when Ticketmaster has no results)

# -------------------------

MEETUP_API_KEY=your_meetup_api_key_here

# -------------------------

# LUMA API

# -------------------------

LUMA_API_KEY=your_luma_api_key_here

# -------------------------

# GOOGLE SEARCH / CUSTOM SEARCH

# Optional

# -------------------------

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# -------------------------

# OPENAI

# Optional future use

# -------------------------

OPENAI_API_KEY=your_openai_api_key_here

# -------------------------

# DATABASE

# Example placeholders

# -------------------------

DATABASE_URL=your_database_url_here

# -------------------------

# DUCK PLAYGROUND API

# Backend service for polls, chat, events, matching, images

# -------------------------

DUCK_PLAYGROUND_API=https://duck-playground.onrender.com

# -------------------------

# SESSION / AUTH

# -------------------------

SESSION_SECRET=replace_with_long_random_secret

# -------------------------

# EMAIL / NOTIFICATIONS

# Optional future use

# -------------------------

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# -------------------------

# MATCH NOTIFICATIONS

# -------------------------

ENABLE_MATCH_NOTIFICATIONS=true

# -------------------------

# CONNECTORS FEATURE FLAGS

# -------------------------

ENABLE_CONNECTORS=true
ENABLE_EVENT_SUGGESTIONS=true
ENABLE_EVENT_MATCHING=true
ENABLE_INSTAGRAM_SHARING=true

# -------------------------

# CACHE

# -------------------------

CACHE_EVENT_RESULTS=true
CACHE_DURATION_MINUTES=60

# -------------------------

# TICKETMASTER API

# Get free key at: https://developer.ticketmaster.com

# -------------------------

TICKETMASTER_API_KEY=6Lx13TiOxPaeXl2ZyueYzN8PX8G99ygL

# -------------------------

# EVENTIM API

# German ticket platform. Get key at: https://developer.eventim.de

# (Third fallback for events when Ticketmaster and Meetup have no results)

# -------------------------

EVENTIM_API_KEY=your_eventim_api_key_here

