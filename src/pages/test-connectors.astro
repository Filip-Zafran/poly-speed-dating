---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Test Connectors - PSD">
  <div class="container">
    <h1>Test Connectors</h1>
    <p>Testing interface for connector functionality and integration.</p>

    <div class="test-section">
      <h2>Available Connectors</h2>
      <div class="connector-list">
        <div class="connector-item">
          <h3>Telegram Connector</h3>
          <p>Test Telegram bot integration and message delivery</p>
          <button class="btn btn-test">Test Connection</button>
        </div>

        <div class="connector-item">
          <h3>Email Connector</h3>
          <p>Verify email delivery and template rendering</p>
          <button class="btn btn-test">Send Test Email</button>
        </div>

        <div class="connector-item">
          <h3>Webhook Connector</h3>
          <p>Test webhook endpoints and payloads</p>
          <button class="btn btn-test">Trigger Test Webhook</button>
        </div>
      </div>
    </div>

    <div class="test-section">
      <h2>Recent Test Logs</h2>
      <div class="logs-box">
        <p>No test logs yet. Run a test to populate this section.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .test-section {
    margin-bottom: 3rem;
  }

  .test-section h2 {
    font-size: 1.3rem;
    margin-bottom: 1.5rem;
    color: #333;
  }

  .connector-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .connector-item {
    background: white;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .connector-item h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .connector-item p {
    color: #666;
    margin-bottom: 1rem;
  }

  .btn-test {
    background: #0066ff;
    color: white;
    padding: 0.6rem 1.2rem;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-test:hover {
    background: #0052cc;
  }

  .logs-box {
    background: #f5f5f5;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 1.5rem;
    font-family: monospace;
    max-height: 300px;
    overflow-y: auto;
  }
</style>
