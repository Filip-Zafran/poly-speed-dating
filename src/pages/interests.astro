---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Interests - PSD">
  <div class="container">
    <h1>My Interests</h1>
    <p>Select your interests and preferences for events.</p>
    
    <div class="interests-form">
      <fieldset class="form-group">
        <legend>What interests you?</legend>
        <label class="checkbox">
          <input type="checkbox" name="interests" value="speed-dating" />
          Speed Dating Events
        </label>
        <label class="checkbox">
          <input type="checkbox" name="interests" value="workshops" />
          Workshops & Learning
        </label>
        <label class="checkbox">
          <input type="checkbox" name="interests" value="socializing" />
          Social Meetups
        </label>
        <label class="checkbox">
          <input type="checkbox" name="interests" value="community" />
          Community Building
        </label>
      </fieldset>

      <fieldset class="form-group">
        <legend>Relationship styles</legend>
        <label class="checkbox">
          <input type="checkbox" name="styles" value="poly" />
          Polyamory
        </label>
        <label class="checkbox">
          <input type="checkbox" name="styles" value="enm" />
          Ethical Non-Monogamy
        </label>
        <label class="checkbox">
          <input type="checkbox" name="styles" value="open" />
          Open Relationships
        </label>
        <label class="checkbox">
          <input type="checkbox" name="styles" value="monogamous" />
          Monogamous
        </label>
      </fieldset>

      <button type="submit" class="btn btn-primary">Save Interests</button>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .form-group {
    margin-bottom: 2rem;
    border: none;
    padding: 0;
  }

  legend {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    display: block;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    cursor: pointer;
    font-weight: 500;
  }

  .checkbox input[type="checkbox"] {
    width: 20px;
    height: 20px;
    cursor: pointer;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    background: #0066ff;
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn:hover {
    background: #0052cc;
  }
</style>
