---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Poly Speed Dating Berlin">
  <main class="linktree-page">
    <section class="linktree-card">
      <div class="linktree-top">
        <img src="/images/PSD-logo.png" alt="PSD Logo" class="linktree-logo" />
        <p class="linktree-intro">
          Meaningful connections in a polyamorous, consent-first, friendly space.
        </p>
        <p style="font-size: 1.1em; color: #666; margin-top: 0.5rem;">📍 Berlin</p>
        <p class="linktree-text">
          Poly Speed Dating (PSD) is a community event that brings polyamorous, enm and poly-curious people together, in-person. It's part of the <a href="https://www.duckdatingapps.com/" target="_blank" rel="noopener noreferrer" style="color: #e50051; font-weight: 700; text-decoration: none;">Duck Dating Apps Project</a>. This format creates space for meaningful conversations and potential matches in an atmosphere of warmth, respect, and inclusivity.
        </p>
      </div>

      <section class="linktree-links">
        <div class="linktree-link linktree-link--highlight" style="display: flex; flex-direction: column; align-items: center; padding: 2rem; gap: 1rem; background: linear-gradient(135deg, #e0f2fe, #bfdbfe); border-radius: 16px;">
          <span class="linktree-link__title">Next Poly Speed Dating event</span>
          <span style="font-size: 1.6em; font-weight: 900;">Wednesday 03.06.2026</span>
          <span style="font-size: 0.9em; color: #1e40af;">Deadline to apply: 22.05.2026</span>
          <a href="https://www.youtube.com/watch?v=ekwBtrL89LY" target="_blank" rel="noopener noreferrer" style="color: #1e40af; text-decoration: none; font-weight: 600; font-size: 0.95em;">Check the video</a>
          <a href="/apply" class="btn" style="background: linear-gradient(135deg, #0066ff, #0099ff); color: white; padding: 1rem 2rem; border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 1.1em; margin-top: 0.5rem; box-shadow: 0 4px 15px rgba(0, 102, 255, 0.3); transition: transform 0.2s, box-shadow 0.2s;">Apply now</a>
        </div>

        <a
          href="https://www.instagram.com/polyfest_berlin/"
          target="_blank"
          rel="noopener noreferrer"
          class="linktree-link"
          style="background: linear-gradient(135deg, #f8a5d3, #f5b3db);"
        >
          <span class="linktree-link__title"><img src="/images/Instagram_icon.png" alt="Instagram" style="height: 24px; margin-right: 8px; vertical-align: middle;"> Instagram — PolyFest</span>
          <span class="linktree-link__meta">@polyfest_berlin</span>
        </a>

        <a
          href="https://www.instagram.com/duck.dating.apps/"
          target="_blank"
          rel="noopener noreferrer"
          class="linktree-link"
          style="background: linear-gradient(135deg, #fdb97e, #fdcba4);"
        >
          <span class="linktree-link__title"><img src="/images/Instagram_icon.png" alt="Instagram" style="height: 24px; margin-right: 8px; vertical-align: middle;"> Instagram — Duck Dating</span>
          <span class="linktree-link__meta">@duck.dating.apps</span>
        </a>

        <a
          href="https://t.me/polyspeeddatingberlin"
          target="_blank"
          rel="noopener noreferrer"
          class="linktree-link"
          style="background: linear-gradient(135deg, #67d5e8, #9ae8f0);"
        >
          <span class="linktree-link__title"><img src="/images/telegram.png" alt="Telegram" style="height: 24px; margin-right: 8px; vertical-align: middle;"> Telegram group</span>
          <span class="linktree-link__meta">t.me/polyspeeddatingberlin</span>
        </a>

        <a
          href="https://www.youtube.com/@DuckDatingApps"
          target="_blank"
          rel="noopener noreferrer"
          class="linktree-link"
          style="background: linear-gradient(135deg, #ff6b6b, #ff5252);"
        >
          <span class="linktree-link__title"><img src="/images/youtube_icon.png" alt="YouTube" style="height: 24px; margin-right: 8px; vertical-align: middle;"> YouTube - Duck Dating</span>
          <span class="linktree-link__meta">@DuckDatingApps</span>
        </a>

        <a
          href="https://www.facebook.com/groups/1741593066664165"
          target="_blank"
          rel="noopener noreferrer"
          class="linktree-link"
          style="background: linear-gradient(135deg, #4267b2, #385495);"
        >
          <span class="linktree-link__title"><img src="/images/fb-logo.png" alt="Facebook" style="height: 24px; margin-right: 8px; vertical-align: middle;"> Poly Speed Dating</span>
          <span class="linktree-link__meta">Facebook Group</span>
        </a>

        <a
          href="/contact"
          class="linktree-link"
          style="background: linear-gradient(135deg, #6ee7b7, #a7f3d0);"
        >
          <span class="linktree-link__title">✉️ Join Mailing List</span>
          <span class="linktree-link__meta">Stay in the loop for future events</span>
        </a>
      </section>

      <div class="linktree-footer-note">
        <p>
          Real conversations. Clear boundaries. Warm community vibe.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .linktree-page {
    padding: 2rem 1rem;
  }

  .linktree-card {
    max-width: 600px;
    margin: 0 auto;
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .linktree-top {
    text-align: center;
    margin-bottom: 2rem;
  }

  .linktree-logo {
    max-width: 280px;
    width: 100%;
    height: auto;
    margin-bottom: 1.5rem;
  }

  .linktree-intro {
    font-size: 1.25em;
    font-weight: 600;
    margin: 1rem 0;
    color: #333;
  }

  .linktree-text {
    font-size: 0.95em;
    line-height: 1.6;
    color: #666;
  }

  .linktree-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .linktree-link {
    display: block;
    padding: 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .linktree-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .linktree-link__title {
    font-weight: 700;
    font-size: 1.1em;
    display: block;
  }

  .linktree-link__meta {
    font-size: 0.9em;
    opacity: 0.9;
    display: block;
  }

  .btn:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 20px rgba(0, 102, 255, 0.4) !important;
  }

  .linktree-footer-note {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid #eee;
    color: #999;
    font-size: 0.95em;
  }

  .linktree-footer-note p {
    margin: 0;
  }
</style>
