---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Poly Merch – PSD">
  <main class="container">
    <h1>Poly Merch</h1>
    <p>Show your poly pride! Our community merch helps fund events and spreads the message of love, openness, and connection.</p>
    <p><small>DISCLAIMER: Still in the making & Shopping Chart is glitchy → for orders please send us an <a href="mailto:polyspeeddatingberlin@gmail.com">e-mail</a>. </small></p>

    <p style="margin:16px 0;">
      <a href="/order" class="btn btn-primary">🛒 View Cart / Checkout</a>
    </p>

    <!-- STICKERS SECTION -->
    <section class="merch-section">
      <h2>Stickers</h2>
      <div class="grid merch-gallery">
        <figure class="merch-item">
          <img src="/images/merch/sticker1.png" alt="Sticker: Attraction is natural" />
          <figcaption>Sticker:<br />"Attraction is natural."</figcaption>
          <button class="add-to-cart" data-sku="sticker1" data-name="Sticker – Attraction is natural" data-price="5">Add to cart — €2</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/sticker2.png" alt="Sticker: Monogamy was just a phase" />
          <figcaption>Sticker:<br />"Monogamy was just a phase."</figcaption>
          <button class="add-to-cart" data-sku="sticker2" data-name="Sticker – Monogamy was just a phase" data-price="5">Add to cart — €2</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/sticker3.png" alt="Sticker: Needs fulfilling machine" />
          <figcaption>Sticker:<br />"Needs fulfilling machine."</figcaption>
          <button class="add-to-cart" data-sku="sticker3" data-name="Sticker – Needs fulfilling machine" data-price="5">Add to cart — €2</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/sticker4.png" alt="Sticker: Poly & Proud" />
          <figcaption>Sticker:<br />"Poly & Proud."</figcaption>
          <button class="add-to-cart" data-sku="sticker4" data-name="Sticker – Poly & Proud" data-price="5">Add to cart — €2</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/sticker5.png" alt="Sticker: Poly isn't easy" />
          <figcaption>Sticker:<br />"Poly isn't easy."</figcaption>
          <button class="add-to-cart" data-sku="sticker5" data-name="Sticker – Poly isn't easy" data-price="5">Add to cart — €2</button>
        </figure>
      </div>
    </section>

    <!-- T-SHIRTS SECTION -->
    <section class="merch-section">
      <h2>T-Shirts</h2>
      <h2 style="color: red;">OUT OF STOCK ATM</h2>
      <div class="grid merch-gallery">
        <figure class="merch-item">
          <img src="/images/merch/shirt1.png" alt="Turquoise t-shirt: Life isn't a Pie" />
          <figcaption>Turquoise t-shirt:<br />"Life isn't a Pie – more slices doesn't mean less for you."</figcaption>
          <button class="add-to-cart" data-sku="shirt1" data-name="T-Shirt – Life isn't a Pie" data-price="19">Add to cart — €19</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/shirt2.png" alt="Green t-shirt: You can choose friends, but not metamours" />
          <figcaption>Green t-shirt:<br />"You can choose friends, but not metamours."</figcaption>
          <button class="add-to-cart" data-sku="shirt2" data-name="T-Shirt – You can choose friends, but not metamours" data-price="19">Add to cart — €19</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/shirt3.png" alt="Grey t-shirt: Your love story doesn't need a single narrator" />
          <figcaption>Grey t-shirt:<br />"Your love story doesn't need a single narrator."</figcaption>
          <button class="add-to-cart" data-sku="shirt3" data-name="T-Shirt – Your love story doesn't need a single narrator" data-price="19">Add to cart — €19</button>
        </figure>

        <figure class="merch-item">
          <img src="/images/merch/shirt4.png" alt="Orange t-shirt: Poly do Boli" />
          <figcaption>Orange t-shirt:<br />"Poly do Boli."</figcaption>
          <button class="add-to-cart" data-sku="shirt4" data-name="T-Shirt – Poly do Boli" data-price="19">Add to cart — €19</button>
        </figure>
      </div>
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .merch-section {
    margin: 3rem 0;
  }

  .merch-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .merch-item {
    text-align: center;
    cursor: pointer;
  }

  .merch-item img {
    width: 100%;
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .merch-item figcaption {
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .add-to-cart {
    padding: 0.75rem 1.5rem;
    background: #0066ff;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: background 0.2s;
  }

  .add-to-cart:hover {
    background: #0052cc;
  }
</style>
